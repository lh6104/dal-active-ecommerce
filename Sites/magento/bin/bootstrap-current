#!/usr/bin/env bash
#
# Re-apply the current DAL Active project state to a running Magento container.
# This is intentionally idempotent and does not delete src/ or reset the DB.
#

set -o errexit
set -o pipefail

DOMAIN=${1:-dalactive.test}
BASE_URL="https://${DOMAIN}/"
SEARCH_HOST=${MAGENTO_SEARCH_HOST:-172.18.0.1}
DB_HOST=${MAGENTO_DB_HOST:-172.18.0.1}
DB_PORT=${MAGENTO_DB_PORT:-3307}

MODULES=(
  Boolfly_MomoWallet
  Boolfly_ZaloPay
  Dalactive_Brand
  Dalactive_EconomicNews
  Dalactive_ExchangeRate
  Dalactive_FlashSale
  Dalactive_HeroBanner
  Dalactive_HybridauthAutoload
  Dalactive_LazyLoad
  Dalactive_PhotoReview
  Dalactive_ProductRecommendation
  Dalactive_SizeGuide
  Dalactive_StockAlert
  Dalactive_StoreLocator
  Dalactive_Weather
  Hiddentechies_Base
  Hiddentechies_Bizkick
  Mageplaza_Core
  Mageplaza_Simpleshipping
  Mageplaza_SocialLogin
  MyVendor_ProductPriceApi
  Vnpayment_VNPAY
)

upsert_config() {
  local path=$1
  local value=$2

  ./bin/cli mysql -h "$DB_HOST" -P "$DB_PORT" -u magento -pmagento magento -e \
    "INSERT INTO core_config_data (scope, scope_id, path, value) VALUES ('default', 0, '${path}', '${value}') ON DUPLICATE KEY UPDATE value=VALUES(value);"
}

echo "================================"
echo "Bootstrapping current DAL Active state"
echo "================================"
echo "Domain: ${DOMAIN}"
echo "Search host: ${SEARCH_HOST}"
echo ""

echo "1. Starting containers without cache watcher..."
./bin/start --no-dev

echo "Waiting for Magento services to accept CLI commands..."
for attempt in {1..18}; do
  if ./bin/clinotty bin/magento cache:status >/dev/null 2>&1; then
    echo "Magento CLI is ready."
    break
  fi

  if [ "$attempt" -eq 18 ]; then
    echo "Magento CLI did not become ready in time."
    ./bin/status || true
    exit 1
  fi

  sleep 5
done

echo ""
echo "2. Copying current code/theme/media into container..."
./bin/copytocontainer app/code
./bin/copytocontainer app/design
./bin/copytocontainer pub/media/logo || true
./bin/copytocontainer pub/media/dalactive/herobanner || true

if [ -d "src/vendor/hybridauth" ]; then
  docker cp src/vendor/hybridauth magento-phpfpm-1:/var/www/html/vendor/
  docker exec magento-phpfpm-1 sh -lc \
    'chown -R app:app /var/www/html/vendor/hybridauth && find /var/www/html/vendor/hybridauth -type d -exec chmod 755 {} + && find /var/www/html/vendor/hybridauth -type f -exec chmod 644 {} +'
fi

echo ""
echo "3. Enabling project modules..."
./bin/clinotty bin/magento module:enable "${MODULES[@]}" --clear-static-content

echo ""
echo "4. Running setup upgrade..."
./bin/clinotty bin/magento setup:upgrade

echo ""
echo "5. Applying project configuration..."
./bin/clinotty bin/magento config:set web/unsecure/base_url "$BASE_URL"
./bin/clinotty bin/magento config:set web/secure/base_url "$BASE_URL"
./bin/clinotty bin/magento config:set web/secure/use_in_frontend 1
./bin/clinotty bin/magento config:set web/secure/use_in_adminhtml 1
./bin/clinotty bin/magento config:set general/locale/code vi_VN
./bin/clinotty bin/magento config:set general/locale/timezone Asia/Ho_Chi_Minh
./bin/clinotty bin/magento config:set currency/options/base VND
./bin/clinotty bin/magento config:set currency/options/default VND
./bin/clinotty bin/magento config:set currency/options/allow VND
./bin/clinotty bin/magento config:set catalog/search/engine elasticsearch7
./bin/clinotty bin/magento config:set catalog/search/elasticsearch7_server_hostname "$SEARCH_HOST"
./bin/clinotty bin/magento config:set catalog/search/elasticsearch7_server_port 9200
./bin/clinotty bin/magento config:set web/default/cms_home_page home

# Keep SocialLogin installed, but do not let it hijack header login/register links.
upsert_config sociallogin/general/popup_login ''
upsert_config sociallogin/general/link_trigger ''
./bin/clinotty bin/magento config:set sociallogin/general/check_mode 0
./bin/clinotty bin/magento config:set sociallogin/general/style_management custom
./bin/clinotty bin/magento config:set sociallogin/general/custom_color '#1477ff'
./bin/clinotty bin/magento config:set sociallogin/general/custom_css '#bnt-social-login-fake-email { background-color: #1477ff !important; border-color: #1477ff !important; } #request-popup .social-login-title, #social-login-popup .social-login-title { background-color: #082642 !important; }'

# Public/default API endpoints only. Do not overwrite private API keys or payment credentials.
upsert_config weather/api/city "Ho Chi Minh City"
upsert_config weather/api/cities "Ho Chi Minh City\nHa Noi\nDa Nang"
upsert_config weather/api/cache_ttl 600
upsert_config exchangerate/api/api_endpoint "https://portal.vietcombank.com.vn/Usercontrols/TVPortal.TyGia/pXML.aspx?b=68"
upsert_config exchangerate/api/cache_ttl 3600
upsert_config economicnews/rss/rss_feed_url "https://vnexpress.net/rss/kinh-doanh.rss"
upsert_config economicnews/rss/items_per_page 21

echo ""
echo "6. Applying Bizkick theme..."
THEME_ID=$(./bin/cli mysql -h "$DB_HOST" -P "$DB_PORT" -u magento -pmagento magento -N -B -e "SELECT theme_id FROM theme WHERE area='frontend' AND theme_path='Hiddentechies/bizkick' LIMIT 1;" | tr -d '\r')
if [ -n "$THEME_ID" ]; then
  ./bin/cli mysql -h "$DB_HOST" -P "$DB_PORT" -u magento -pmagento magento -e "INSERT INTO core_config_data (scope, scope_id, path, value) VALUES ('default', 0, 'design/theme/theme_id', '${THEME_ID}') ON DUPLICATE KEY UPDATE value=VALUES(value);"
  echo "Theme Hiddentechies/bizkick applied with theme_id=${THEME_ID}"
else
  echo "WARNING: Hiddentechies/bizkick theme was not found in Magento theme table."
fi

echo ""
echo "7. Initializing DAL Active store config and logos..."
./bin/init-dalactive-config
./bin/init-dalactive-logos

echo ""
echo "8. Deploying static content..."
./bin/clinotty bin/magento setup:static-content:deploy -f vi_VN en_US

echo ""
echo "9. Reindexing and flushing cache..."
./bin/clinotty bin/magento indexer:reindex
./bin/clinotty bin/magento cache:flush
./bin/fixowns
./bin/fixperms

echo ""
echo "10. Verifying enabled modules..."
./bin/clinotty bin/magento module:status "${MODULES[@]}"

echo ""
echo "================================"
echo "Current DAL Active state is ready"
echo "================================"
echo "Storefront: ${BASE_URL}"
echo "Admin: ${BASE_URL}admin"
