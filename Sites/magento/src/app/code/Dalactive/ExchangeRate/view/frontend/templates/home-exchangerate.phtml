$rates = $block->getHomepageRates();
$flags = [
    'AUD' => '🇦🇺',
    'CAD' => '🇨🇦',
    'CHF' => '🇨🇭',
    'CNY' => '🇨🇳',
    'DKK' => '🇩🇰',
    'EUR' => '🇪🇺',
    'GBP' => '🇬🇧',
    'HKD' => '🇭🇰',
    'INR' => '🇮🇳',
    'JPY' => '🇯🇵',
    'KRW' => '🇰🇷',
    'KWD' => '🇰🇼',
    'MYR' => '🇲🇾',
    'NOK' => '🇳🇴',
    'RUB' => '🇷🇺',
    'SAR' => '🇸🇦',
    'SEK' => '🇸🇪',
    'SGD' => '🇸🇬',
    'THB' => '🇹🇭',
    'USD' => '🇺🇸',
];
$rateFields = [
    'buy' => __('Mua'),
    'transfer' => __('CK'),
    'sell' => __('Bán'),
];
?>
<section class="dalactive-home-rates" aria-labelledby="dalactive-home-rates-title">
    <div class="page-main">
        <div class="page-title-main">
            <strong id="dalactive-home-rates-title" role="heading" aria-level="2">
                <?= $block->escapeHtml(__('Tỷ giá')) ?>
            </strong>
        </div>

        <div class="dalactive-home-rates__panel">
            <div class="dalactive-home-rates__label">
                <span><?= $block->escapeHtml(__('Tỷ giá VCB')) ?></span>
                <small><?= $block->escapeHtml(__('Cập nhật hàng ngày')) ?></small>
            </div>

            <?php if (!empty($rates)): ?>
                <ul class="dalactive-home-rates__list">
                    <?php foreach ($rates as $currency => $rate): ?>
                        <li class="dalactive-home-rates__item">
                            <div class="dalactive-home-rates__head">
                                <span class="dalactive-home-rates__code">
                                    <?php if (isset($flags[$currency])): ?>
                                        <span aria-hidden="true"><?= $block->escapeHtml($flags[$currency]) ?></span>
                                    <?php endif; ?>
                                    <?= $block->escapeHtml($currency) ?>
                                </span>
                            </div>
                            <div class="dalactive-home-rates__values">
                                <?php foreach ($rateFields as $field => $label): ?>
                                    <span class="dalactive-home-rates__value">
                                        <small><?= $block->escapeHtml($label) ?></small>
                                        <strong><?= $block->escapeHtml($block->formatRate($rate[$field] ?? null)) ?></strong>
                                    </span>
                                <?php endforeach; ?>
                            </div>
                        </li>
                    <?php endforeach; ?>
                </ul>
            <?php else: ?>
                <p class="dalactive-home-rates__empty"><?= $block->escapeHtml(__('Chưa có dữ liệu tỷ giá.')) ?></p>
            <?php endif; ?>

            <div class="dalactive-home-rates__actions">
                <a class="dalactive-home-rates__link" href="<?= $block->escapeUrl($block->getViewAllUrl()) ?>">
                    <?= $block->escapeHtml(__('Chi tiết')) ?>
                </a>
            </div>
        </div>
    </div>
</section>
