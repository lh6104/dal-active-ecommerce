<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="quote_address" resource="default" engine="innodb">
        <column xsi:type="int" name="ghn_province_id" unsigned="true" nullable="true"/>
        <column xsi:type="int" name="ghn_district_id" unsigned="true" nullable="true"/>
        <column xsi:type="varchar" name="ghn_ward_code" nullable="true" length="32"/>
        <column xsi:type="varchar" name="ghn_province_name" nullable="true" length="255"/>
        <column xsi:type="varchar" name="ghn_district_name" nullable="true" length="255"/>
        <column xsi:type="varchar" name="ghn_ward_name" nullable="true" length="255"/>
    </table>
    <table name="sales_order_address" resource="default" engine="innodb">
        <column xsi:type="int" name="ghn_province_id" unsigned="true" nullable="true"/>
        <column xsi:type="int" name="ghn_district_id" unsigned="true" nullable="true"/>
        <column xsi:type="varchar" name="ghn_ward_code" nullable="true" length="32"/>
        <column xsi:type="varchar" name="ghn_province_name" nullable="true" length="255"/>
        <column xsi:type="varchar" name="ghn_district_name" nullable="true" length="255"/>
        <column xsi:type="varchar" name="ghn_ward_name" nullable="true" length="255"/>
    </table>
</schema>
