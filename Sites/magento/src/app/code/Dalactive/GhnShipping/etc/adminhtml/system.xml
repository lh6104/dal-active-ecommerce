<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="carriers" translate="label" type="text" sortOrder="320" showInDefault="1" showInWebsite="1" showInStore="1">
            <group id="ghn" translate="label" type="text" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>GHN Express</label>
                <field id="active" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="title" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Title</label>
                </field>
                <field id="name" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Method Name</label>
                </field>
                <field id="environment" translate="label" type="select" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Environment</label>
                    <source_model>Dalactive\GhnShipping\Model\Config\Source\Environment</source_model>
                </field>
                <field id="sandbox_base_url" translate="label" type="text" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Sandbox Base URL</label>
                    <validate>validate-url</validate>
                </field>
                <field id="production_base_url" translate="label" type="text" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Production Base URL</label>
                    <validate>validate-url</validate>
                </field>
                <field id="token" translate="label" type="obscure" sortOrder="70" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Token</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                </field>
                <field id="shop_id" translate="label" type="text" sortOrder="80" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Shop ID</label>
                    <validate>validate-digits</validate>
                </field>
                <field id="from_district_id" translate="label" type="text" sortOrder="90" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>From District ID</label>
                    <validate>validate-digits</validate>
                </field>
                <field id="from_ward_code" translate="label" type="text" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Legacy From Ward Code</label>
                    <comment>Used only if selected Store Locator origin has no GHN ward code.</comment>
                </field>
                <field id="enable_auto_mapping" translate="label" type="select" sortOrder="105" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Enable Automatic GHN Address Mapping</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="enable_nearest_origin" translate="label comment" type="select" sortOrder="106" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Enable Nearest Origin Store</label>
                    <comment>Uses coordinates if available, then province/district matching, then default origin.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="default_origin_store_code" translate="label comment" type="select" sortOrder="107" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Default Origin Store</label>
                    <comment>Loaded from DAL Active Store Locator.</comment>
                    <source_model>Dalactive\GhnShipping\Model\Config\Source\OriginStore</source_model>
                </field>
                <field id="enable_checkout_dropdowns" translate="label comment" type="select" sortOrder="108" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Enable GHN Address Dropdowns in Checkout</label>
                    <comment>Loads province, district, and ward from backend /ghn/address/* endpoints. GHN token is never exposed to frontend JavaScript.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="enable_name_resolver" translate="label comment" type="select" sortOrder="109" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Enable Name-Based Address Resolver</label>
                    <comment>Matches Magento city/region/street text against GHN cached master data.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="address_cache_ttl" translate="label comment" type="text" sortOrder="125" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>GHN Address Cache TTL (seconds)</label>
                    <comment>Default is 86400 seconds.</comment>
                    <validate>validate-digits</validate>
                </field>
                <field id="default_service_id" translate="label comment" type="text" sortOrder="130" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Default Service ID</label>
                    <comment>Optional. If empty, available-services is called first.</comment>
                    <validate>validate-digits</validate>
                </field>
                <field id="default_service_type_id" translate="label" type="text" sortOrder="140" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Default Service Type ID</label>
                    <validate>validate-digits</validate>
                </field>
                <field id="default_weight" translate="label" type="text" sortOrder="150" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Default Package Weight (grams)</label>
                    <validate>validate-digits</validate>
                </field>
                <field id="default_length" translate="label" type="text" sortOrder="160" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Default Length (cm)</label>
                    <validate>validate-digits</validate>
                </field>
                <field id="default_width" translate="label" type="text" sortOrder="170" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Default Width (cm)</label>
                    <validate>validate-digits</validate>
                </field>
                <field id="default_height" translate="label" type="text" sortOrder="180" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Default Height (cm)</label>
                    <validate>validate-digits</validate>
                </field>
                <field id="coupon" translate="label comment" type="text" sortOrder="185" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>GHN Coupon Code</label>
                    <comment>Optional coupon sent to GHN fee API.</comment>
                </field>
                <field id="insurance_value_mode" translate="label comment" type="select" sortOrder="186" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Insurance Value Mode</label>
                    <comment>Controls the insurance_value sent to GHN fee API.</comment>
                    <source_model>Dalactive\GhnShipping\Model\Config\Source\InsuranceMode</source_model>
                </field>
                <field id="insurance_value_fixed" translate="label comment" type="text" sortOrder="187" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Fixed Insurance Value</label>
                    <comment>Used only when Insurance Value Mode is Fixed Value.</comment>
                    <validate>validate-number</validate>
                </field>
                <field id="max_insurance_value" translate="label comment" type="text" sortOrder="188" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Maximum Insurance Value</label>
                    <comment>Set 0 to use full cart subtotal.</comment>
                    <validate>validate-number</validate>
                </field>
                <field id="free_shipping_threshold" translate="label comment" type="text" sortOrder="190" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Free Shipping Threshold</label>
                    <comment>Set 0 to disable.</comment>
                    <validate>validate-number</validate>
                </field>
                <field id="use_fallback_on_api_failure" translate="label comment" type="select" sortOrder="200" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Use Fallback Fee on API Failure</label>
                    <comment>If No, GHN is hidden with a clear checkout message when address is incomplete or GHN API fails.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="fallback_fee" translate="label comment" type="text" sortOrder="205" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Fallback Shipping Fee</label>
                    <comment>Used only when fallback is enabled above.</comment>
                    <validate>validate-number</validate>
                </field>
                <field id="debug" translate="label" type="select" sortOrder="210" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Debug Logging</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="showmethod" translate="label comment" type="select" sortOrder="215" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Show Method if Not Calculable</label>
                    <comment>Shows GHN with a checkout-safe error message when the address is incomplete or GHN API cannot return a fee.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="specificerrmsg" translate="label comment" type="textarea" sortOrder="216" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Displayed Error Message</label>
                    <comment>Fallback admin-safe message used when GHN cannot calculate a rate.</comment>
                </field>
                <field id="sort_order" translate="label" type="text" sortOrder="220" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Sort Order</label>
                    <validate>validate-number</validate>
                </field>
                <field id="sallowspecific" translate="label" type="select" sortOrder="230" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Ship to Applicable Countries</label>
                    <frontend_class>shipping-applicable-country</frontend_class>
                    <source_model>Magento\Shipping\Model\Config\Source\Allspecificcountries</source_model>
                </field>
                <field id="specificcountry" translate="label" type="multiselect" sortOrder="240" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Ship to Specific Countries</label>
                    <source_model>Magento\Directory\Model\Config\Source\Country</source_model>
                    <can_be_empty>1</can_be_empty>
                </field>
            </group>
        </section>
    </system>
</config>
