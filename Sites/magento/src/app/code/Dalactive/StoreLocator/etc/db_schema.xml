<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="dalactive_storelocator_store" resource="default" engine="innodb" comment="Dalactive Store Locator Stores">
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" identity="true"/>
        <column xsi:type="varchar" name="name" nullable="false" length="255"/>
        <column xsi:type="varchar" name="identifier" nullable="false" length="255"/>
        <column xsi:type="text" name="address" nullable="false"/>
        <column xsi:type="varchar" name="city" nullable="true" length="128"/>
        <column xsi:type="varchar" name="region" nullable="true" length="128"/>
        <column xsi:type="varchar" name="country" nullable="false" default="VN" length="64"/>
        <column xsi:type="decimal" name="latitude" scale="7" precision="10" nullable="true"/>
        <column xsi:type="decimal" name="longitude" scale="7" precision="10" nullable="true"/>
        <column xsi:type="text" name="google_maps_url" nullable="true"/>
        <column xsi:type="varchar" name="phone" nullable="true" length="64"/>
        <column xsi:type="varchar" name="email" nullable="true" length="255"/>
        <column xsi:type="varchar" name="opening_hours" nullable="true" length="255"/>
        <column xsi:type="smallint" name="is_active" unsigned="true" nullable="false" default="1"/>
        <column xsi:type="int" name="sort_order" nullable="false" default="0"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="DALACTIVE_STORELOCATOR_STORE_IDENTIFIER">
            <column name="identifier"/>
        </constraint>
        <index referenceId="DALACTIVE_STORELOCATOR_STORE_ACTIVE_SORT" indexType="btree">
            <column name="is_active"/>
            <column name="sort_order"/>
        </index>
    </table>
</schema>
