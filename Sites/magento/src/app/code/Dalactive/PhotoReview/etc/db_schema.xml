<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="dalactive_photoreview_image" resource="default" engine="innodb" comment="Dalactive Photo Review Images">
        <column xsi:type="int" name="image_id" unsigned="true" nullable="false" identity="true"/>
        <column xsi:type="bigint" name="review_id" unsigned="true" nullable="true"/>
        <column xsi:type="int" name="customer_id" unsigned="true" nullable="true"/>
        <column xsi:type="int" name="product_id" unsigned="true" nullable="false"/>
        <column xsi:type="text" name="comment" nullable="true"/>
        <column xsi:type="varchar" name="image_path" nullable="false" length="255"/>
        <column xsi:type="smallint" name="status" unsigned="true" nullable="false" default="1" comment="1 Pending, 2 Approved, 3 Rejected"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="image_id"/>
        </constraint>
    </table>
</schema>
