<?php
/** @var \Dalactive\EconomicNews\Block\News $block */
$articles = $block->getHomepageNewsItems(3);
?>
<section class="dalactive-home-news dalactive-home-news--economic" aria-labelledby="dalactive-home-economic-title">
    <div class="page-main">
        <div class="page-title-main">
            <strong id="dalactive-home-economic-title" role="heading" aria-level="2">
                <?= $block->escapeHtml(__('Tin kinh tế')) ?>
            </strong>
        </div>

        <?php if (!empty($articles)): ?>
            <div class="dalactive-home-news__grid dalactive-home-news__grid--balanced">
                <?php foreach ($articles as $article): ?>
                    <?php
                    $title = (string) $article->getTitle();
                    $link = (string) $article->getLink();
                    $description = (string) $article->getDescription();
                    $image = (string) $article->getImage();
                    $date = $block->formatNewsDate((string) $article->getPubDate());
                    ?>
                    <article class="dalactive-home-news__card">
                        <a class="dalactive-home-news__media<?= $image === '' ? ' is-placeholder' : '' ?>"
                           href="<?= $block->escapeUrl($link) ?>"
                           target="_blank"
                           rel="noopener noreferrer"
                           aria-label="<?= $block->escapeHtmlAttr($title) ?>"
                           <?php if ($image !== ''): ?>
                           style="background-image: url('<?= $block->escapeUrl($image) ?>')"
                           <?php endif; ?>>
                            <?php if ($image === ''): ?>
                                <span><?= $block->escapeHtml(__('Tin tức')) ?></span>
                            <?php endif; ?>
                        </a>
                        <div class="dalactive-home-news__body">
                            <?php if ($date !== ''): ?>
                                <time class="dalactive-home-news__date" datetime="<?= $block->escapeHtmlAttr($article->getPubDate()) ?>">
                                    <?= $block->escapeHtml($date) ?>
                                </time>
                            <?php endif; ?>
                            <h3 class="dalactive-home-news__title">
                                <a href="<?= $block->escapeUrl($link) ?>"
                                   target="_blank"
                                   rel="noopener noreferrer">
                                    <?= $block->escapeHtml($title) ?>
                                </a>
                            </h3>
                            <?php if ($description !== ''): ?>
                                <p class="dalactive-home-news__excerpt">
                                    <?= $block->escapeHtml(strip_tags($description)) ?>
                                </p>
                            <?php endif; ?>
                            <a class="dalactive-home-news__read"
                               href="<?= $block->escapeUrl($link) ?>"
                               target="_blank"
                               rel="noopener noreferrer">
                                <?= $block->escapeHtml(__('Đọc thêm')) ?> →
                            </a>
                        </div>
                    </article>
                <?php endforeach; ?>
            </div>
        <?php else: ?>
            <p class="dalactive-home-news__empty">
                <?= $block->escapeHtml(__('Hiện chưa có tin tức để hiển thị.')) ?>
            </p>
        <?php endif; ?>

        <div class="dalactive-home-news__toolbar">
            <a class="dalactive-home-news__view-all" href="<?= $block->escapeUrl($block->getViewAllUrl()) ?>">
                <?= $block->escapeHtml(__('Xem tất cả tin kinh tế')) ?>
            </a>
        </div>
    </div>
</section>
