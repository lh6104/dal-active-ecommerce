<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="content">
            <block class="Dalactive\SizeGuide\Block\Adminhtml\Listing"
                   name="dalactive.stockalert.admin.listing"
                   template="Dalactive_SizeGuide::listing.phtml">
                <arguments>
                    <argument name="table" xsi:type="string">dalactive_stockalert_subscriber</argument>
                    <argument name="columns" xsi:type="string">subscriber_id,email,product_id,product_option,subscribe_date,notification_status</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
