<?php
/**
 * @var \Dalactive\PhotoReview\Block\Product\ReviewCards $block
 */
$_reviews = array_values($block->getReviewsCollection()->getItems());
$_reviewCount = count($_reviews);
$_previewReview = $_reviews[0] ?? null;
$_format = $block->getDateFormat() ?: \IntlDateFormatter::MEDIUM;
$_product = $block->getProduct();
$_productImage = $_product ? (string) $_product->getImage() : '';
$_productImageUrl = ($_productImage && $_productImage !== 'no_selection')
    ? rtrim($block->getBaseUrl(), '/') . '/media/catalog/product' . $_productImage
    : $block->getViewFileUrl('Magento_Catalog::images/product/placeholder/thumbnail.jpg');

$_getReviewScore = static function ($review): float {
    $votes = $review->getRatingVotes();
    if (!$votes || !count($votes)) {
        return 0.0;
    }

    $total = 0.0;
    $count = 0;
    foreach ($votes as $vote) {
        $total += ((float) $vote->getPercent()) / 20;
        $count++;
    }

    return $count ? round($total / $count, 1) : 0.0;
};

$_totalScore = 0.0;
$_scoredReviews = 0;
foreach ($_reviews as $_review) {
    $_score = $_getReviewScore($_review);
    if ($_score > 0) {
        $_totalScore += $_score;
        $_scoredReviews++;
    }
}
$_averageScore = $_scoredReviews ? round($_totalScore / $_scoredReviews, 1) : 0.0;

$_renderStars = static function (float $score) use ($block): string {
    $rounded = (int) round($score);
    $html = '<span class="dal-review-stars" aria-label="' . $block->escapeHtmlAttr(__('%1 out of 5 stars', $score ?: 0)) . '">';
    for ($i = 1; $i <= 5; $i++) {
        $html .= '<span class="' . ($i <= $rounded ? 'is-filled' : '') . '" aria-hidden="true">★</span>';
    }
    $html .= '</span>';

    return $html;
};

$_renderCard = function ($review, bool $isCompact = false) use ($block, $_format, $_getReviewScore, $_renderStars): string {
    $_nickname = trim((string) $review->getNickname()) ?: (string) __('Khách hàng');
    $_initial = function_exists('mb_substr') ? mb_substr($_nickname, 0, 1) : substr($_nickname, 0, 1);
    $_score = $_getReviewScore($review);
    $_images = $block->getImagesForReview((int) $review->getReviewId());

    ob_start();
    ?>
    <article class="dal-review-card<?= $isCompact ? ' is-compact' : '' ?>" itemscope itemprop="review" itemtype="http://schema.org/Review">
        <div class="dal-review-card__top">
            <div class="dal-review-avatar" aria-hidden="true"><?= $block->escapeHtml(strtoupper($_initial)) ?></div>
            <div class="dal-review-card__meta">
                <strong itemprop="author"><?= $block->escapeHtml($_nickname) ?></strong>
                <div class="dal-review-card__rating">
                    <?= /* @noEscape */ $_renderStars($_score) ?>
                    <?php if ($_score > 0): ?>
                        <span><?= $block->escapeHtml(number_format($_score, 1)) ?>/5</span>
                    <?php endif; ?>
                </div>
            </div>
            <?php if ($review->getCreatedAt()): ?>
                <time class="dal-review-date" itemprop="datePublished"
                      datetime="<?= $block->escapeHtmlAttr($block->formatDate($review->getCreatedAt(), $_format)) ?>">
                    <?= $block->escapeHtml($block->formatDate($review->getCreatedAt(), $_format)) ?>
                </time>
            <?php endif; ?>
        </div>

        <?php if (trim((string) $review->getTitle())): ?>
            <h4 class="dal-review-card__title" itemprop="name"><?= $block->escapeHtml($review->getTitle()) ?></h4>
        <?php endif; ?>

        <?php if (trim((string) $review->getDetail())): ?>
            <div class="dal-review-card__content" itemprop="description">
                <?= /* @noEscape */ nl2br($block->escapeHtml($review->getDetail())) ?>
            </div>
        <?php endif; ?>

        <?php if ($_images): ?>
            <div class="dal-review-images" aria-label="<?= $block->escapeHtmlAttr(__('Ảnh đánh giá')) ?>">
                <?php foreach (array_slice($_images, 0, 5) as $_imageUrl): ?>
                    <img src="<?= $block->escapeUrl($_imageUrl) ?>"
                         alt="<?= $block->escapeHtmlAttr(__('Ảnh đánh giá của %1', $_nickname)) ?>"
                         loading="lazy"/>
                <?php endforeach; ?>
            </div>
        <?php endif; ?>
    </article>
    <?php
    return (string) ob_get_clean();
};
?>

<div class="dal-review-section-panel">
    <div class="dal-review-summary-card">
        <div class="dal-review-summary-header">
            <h3><?= $block->escapeHtml(__('Các nhận xét')) ?></h3>
            <?php if ($_reviewCount): ?>
                <div class="dal-review-rating">
                    <span class="dal-review-score-text"><?= $block->escapeHtml(number_format($_averageScore, 1)) ?>/5</span>
                    <?= /* @noEscape */ $_renderStars($_averageScore) ?>
                    <span class="dal-review-count"><?= $block->escapeHtml(__('%1 nhận xét', $_reviewCount)) ?></span>
                </div>
            <?php endif; ?>
        </div>

        <div class="dal-review-preview">
            <?php if ($_previewReview): ?>
                <?= /* @noEscape */ $_renderCard($_previewReview, true) ?>
            <?php else: ?>
                <p class="dal-review-empty-text">
                    <?= $block->escapeHtml(__('Chưa có nhận xét nào. Hãy là người đầu tiên đánh giá sản phẩm này.')) ?>
                </p>
            <?php endif; ?>

            <?php if ($block->isPhotoReviewEnabled()): ?>
                <p class="dal-review-photo-note">
                    <?= $block->escapeHtml(__('Thêm tối đa %1 ảnh, mỗi ảnh tối đa %2MB.', $block->getMaxImages(), $block->getMaxImageSizeMb())) ?>
                </p>
            <?php endif; ?>
        </div>

        <div class="dal-review-actions">
            <button type="button"
                    class="dal-review-button is-secondary"
                    data-review-modal-open="list">
                <?= $block->escapeHtml(__('Xem tất cả nhận xét')) ?>
            </button>
            <a href="#review-form"
               class="dal-review-button is-primary"
               data-review-modal-open="write">
                <?= $block->escapeHtml(__('Viết nhận xét')) ?>
            </a>
        </div>
    </div>
</div>

<div class="dal-review-overlay" data-review-list-modal-overlay hidden></div>
<section class="dal-review-modal dal-review-list-modal"
         role="dialog"
         aria-modal="true"
         aria-labelledby="dal-review-list-modal-title"
         data-review-list-modal
         hidden>
    <div class="dal-review-modal__panel" tabindex="-1">
        <button type="button"
                class="dal-review-modal__close"
                aria-label="<?= $block->escapeHtmlAttr(__('Đóng danh sách nhận xét')) ?>"
                data-review-list-modal-close>
            <span aria-hidden="true">×</span>
        </button>
        <header class="dal-review-modal__header">
            <?php if ($_product): ?>
                <div class="dal-review-list-product">
                    <img src="<?= $block->escapeUrl($_productImageUrl) ?>"
                         alt="<?= $block->escapeHtmlAttr($_product->getName()) ?>"
                         loading="lazy"/>
                    <strong><?= $block->escapeHtml($_product->getName()) ?></strong>
                </div>
            <?php endif; ?>
            <h2 id="dal-review-list-modal-title"><?= $block->escapeHtml(__('Tất cả nhận xét')) ?></h2>
            <?php if ($_reviewCount): ?>
                <div class="dal-review-score is-centered">
                    <strong><?= $block->escapeHtml(number_format($_averageScore, 1)) ?>/5</strong>
                    <?= /* @noEscape */ $_renderStars($_averageScore) ?>
                    <span><?= $block->escapeHtml(__('%1 nhận xét', $_reviewCount)) ?></span>
                </div>
            <?php endif; ?>
        </header>

        <?php if ($_reviews): ?>
            <div class="dal-review-card-list is-modal">
                <?php foreach ($_reviews as $_review): ?>
                    <?= /* @noEscape */ $_renderCard($_review) ?>
                <?php endforeach; ?>
            </div>
        <?php else: ?>
            <div class="dal-review-empty">
                <p><?= $block->escapeHtml(__('Chưa có nhận xét nào. Hãy là người đầu tiên đánh giá sản phẩm này.')) ?></p>
            </div>
        <?php endif; ?>

        <div class="dal-review-modal-actions">
            <a href="#review-form" class="dal-review-button is-primary" data-review-modal-open="write" data-review-list-modal-close>
                <?= $block->escapeHtml(__('Viết nhận xét')) ?>
            </a>
        </div>
    </div>
</section>
