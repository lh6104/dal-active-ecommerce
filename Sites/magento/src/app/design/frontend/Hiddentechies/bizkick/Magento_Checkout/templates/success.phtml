<?php
/** @var \Dalactive\CheckoutFix\Block\Onepage\Success $block */
$order = $block->getOrder();
$shippingAddress = $order ? $order->getShippingAddress() : null;
$billingAddress = $order ? $order->getBillingAddress() : null;
$paymentTitle = $block->getPaymentTitle();
$shippingDescription = $block->getShippingDescription();
$supportPhone = $block->getSupportPhone() ?: '84886698386';
$supportEmail = $block->getSupportEmail() ?: 'dalactive99@gmail.com';
$status = $order ? (string) $order->getStatus() : '';
$state = $order ? (string) $order->getState() : '';
$isPaidLike = in_array($state, ['processing', 'complete'], true);
$isCanceled = in_array($state, ['canceled', 'closed'], true);
$timeline = [
    ['key' => 'placed', 'label' => __('Đặt hàng'), 'state' => 'is-complete'],
    ['key' => 'payment', 'label' => __('Thanh toán'), 'state' => $isPaidLike ? 'is-complete' : ($isCanceled ? 'is-muted' : 'is-current')],
    ['key' => 'processing', 'label' => __('Xử lý'), 'state' => $isPaidLike ? 'is-current' : ''],
    ['key' => 'shipping', 'label' => __('Giao hàng'), 'state' => ''],
    ['key' => 'done', 'label' => __('Hoàn tất'), 'state' => ''],
];
?>
