<?php
/**
 * Product configurable options with server-rendered option fallback.
 *
 * Magento normally injects configurable option values with JavaScript. Rendering
 * them here as well keeps size selection usable if JS loads late or fails.
 */
?>
<?php
/** @var $block \Magento\ConfigurableProduct\Block\Product\View\Type\Configurable */
$_product = $block->getProduct();
$_attributes = $block->decorateArray($block->getAllowAttributes());
?>
<?php if ($_product->isSaleable() && count($_attributes)) : ?>
    <?php foreach ($_attributes as $_attribute) : ?>
        <?php
        $attributeId = (int) $_attribute->getAttributeId();
        $attributeLabel = $_attribute->getProductAttribute()->getStoreLabel();
        ?>
        <div class="field configurable required">
            <label class="label" for="attribute<?= $block->escapeHtmlAttr((string) $attributeId) ?>">
                <span><?= $block->escapeHtml($attributeLabel) ?></span>
            </label>
            <div class="control">
                <select name="super_attribute[<?= $block->escapeHtmlAttr((string) $attributeId) ?>]"
                        data-selector="super_attribute[<?= $block->escapeHtmlAttr((string) $attributeId) ?>]"
                        data-validate="{required:true}"
                        id="attribute<?= $block->escapeHtmlAttr((string) $attributeId) ?>"
                        class="super-attribute-select">
                    <option value=""><?= $block->escapeHtml(__('Choose an Option...')) ?></option>
                    <?php foreach ((array) $_attribute->getOptions() as $_option) : ?>
                        <?php
                        $optionValue = (string) ($_option['value_index'] ?? '');
                        $optionLabel = (string) ($_option['label'] ?? $_option['default_label'] ?? '');
                        ?>
                        <?php if ($optionValue !== '' && $optionLabel !== '') : ?>
                            <option value="<?= $block->escapeHtmlAttr($optionValue) ?>">
                                <?= $block->escapeHtml($optionLabel) ?>
                            </option>
                        <?php endif; ?>
                    <?php endforeach; ?>
                </select>
            </div>
        </div>
    <?php endforeach; ?>
    <script type="text/x-magento-init">
        {
            "#product_addtocart_form": {
                "configurable": {
                    "spConfig": <?= /* @noEscape */ $block->getJsonConfig() ?>,
                    "gallerySwitchStrategy": "<?= $block->escapeJs($block->getVar(
                        'gallery_switch_strategy',
                        'Magento_ConfigurableProduct'
                    ) ?: 'replace'); ?>"
                }
            },
            "*" : {
                "Magento_ConfigurableProduct/js/catalog-add-to-cart": {}
            }
        }
    </script>
<?php endif; ?>
