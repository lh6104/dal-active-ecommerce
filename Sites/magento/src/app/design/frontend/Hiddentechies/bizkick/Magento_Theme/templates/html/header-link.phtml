<?php
/**
 * @var \Magento\Framework\View\Element\Template $block
 */
$path = (string) $block->getData('path');
$label = (string) $block->getData('label');
?>
<?php if ($path && $label) { ?>
    <li class="nav item">
        <a href="<?php echo $block->escapeUrl($block->getUrl($path)); ?>">
            <?php echo $block->escapeHtml(__($label)); ?>
        </a>
    </li>
<?php } ?>
